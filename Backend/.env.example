TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Configure GEMINI_API_KEY diretamente nas Environment Variables do Render.
# Para rodar localmente, você também pode criar essa variável no seu .env real.

# URL pública do serviço no Render, sem barra final. Exemplo:
# PUBLIC_BASE_URL=https://colorglass-bot.onrender.com
PUBLIC_BASE_URL=

# Opcionais
# Prompt livre usado quando a mensagem não é uma ação operacional.
ASSISTANT_PROMPT=Você é um assistente virtual da ColorGlass Fortaleza. Converse de forma natural, educada e objetiva em português do Brasil. Ajude com dúvidas sobre pedidos, orçamentos, produtos, atendimento e informações gerais. Nunca diga que salvou, alterou ou atualizou dados no sistema.
GEMINI_MODEL=gemini-2.0-flash
FLASK_HOST=0.0.0.0
# Render define PORT automaticamente. FLASK_PORT é usado só como fallback local.
FLASK_PORT=5000
FLASK_DEBUG=false
SUPABASE_PEDIDOS_TABLE=orcamentos
SUPABASE_ORCAMENTOS_TABLE=orcamentos
SUPABASE_CONVERSATION_STATE_TABLE=conversation_states
# Tabelas liberadas para visualização somente leitura pela IA.
SUPABASE_READ_TABLES=orcamentos,pagamentos,portas,usuarios,clientes,materiais,perfis,vidros,puxadores,trilhos,sistemas,fornecedores,tarefas,tags,comprovantes,estruturas
