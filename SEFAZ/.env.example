# Ambiente: homologacao ou producao
# Este MVP aceita somente homologacao / tpAmb=2
SEFAZ_AMBIENTE=homologacao
SEFAZ_TP_AMB=2

# Servidor local de teste
SEFAZ_TEST_PORT=5055

# UF da empresa emitente. Ex: CE
SEFAZ_UF=CE

# Código IBGE da UF. CE = 23
SEFAZ_CUF=23

# CNPJ do emitente, somente números
SEFAZ_CNPJ_EMITENTE=00000000000000

# Certificado A1
# Nunca commitar certificado, senha ou chave privada.
SEFAZ_CERT_PFX_PATH=/caminho/local/certificado-a1.pfx
SEFAZ_CERT_PASSWORD=senha_do_certificado

# Para requests/Flask, prefira usar PEM local.
# Conversão comum:
# openssl pkcs12 -in certificado.pfx -clcerts -nokeys -out cert.pem
# openssl pkcs12 -in certificado.pfx -nocerts -nodes -out key.pem
SEFAZ_CERT_PEM_PATH=/caminho/local/cert.pem
SEFAZ_KEY_PEM_PATH=/caminho/local/key.pem

# URLs dos webservices. Confirmar no Portal NF-e / SEFAZ antes de usar.
SEFAZ_STATUS_URL=https://URL-DE-HOMOLOGACAO/NFeStatusServico4
SEFAZ_AUTORIZACAO_URL=https://URL-DE-HOMOLOGACAO/NFeAutorizacao4
SEFAZ_RET_AUTORIZACAO_URL=https://URL-DE-HOMOLOGACAO/NFeRetAutorizacao4

# Versão do leiaute NF-e
SEFAZ_VERSAO=4.00
